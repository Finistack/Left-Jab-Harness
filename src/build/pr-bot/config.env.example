# PR Bot Configuration — Template
# Copy this to config.env and fill in your values.
# Secrets (ADO_PAT, ANTHROPIC_AUTH_TOKEN, etc.) should go in .secrets.env (gitignored).
#
# IMPORTANT — use PLAIN literal values (VAR=value), not shell expansion (VAR="${VAR:-x}").
# This file is loaded two ways: bash `source` (start.sh) AND systemd `EnvironmentFile=`.
# systemd does NOT expand ${...}, so a self-referential `VAR="${VAR:-2700}"` is passed to
# the daemon as the literal string "${VAR:-2700}" and breaks arithmetic/comparisons.
# Keep every line a literal assignment; the validator also forbids $(...) and backticks.

# ── Azure DevOps ──
# Your Azure DevOps org/project/repo. The bot operates on TARGET_REPO_DIR (below);
# these identify the same repo for ADO REST API calls (PRs, threads, work items).
ADO_ORG="your-org"
ADO_PROJECT="your-project"
ADO_REPO="your-repo"

# Authentication method: "pat" | "entra-sp" | "entra-wi"
#   pat       — Personal Access Token (set ADO_PAT in .secrets.env)
#   entra-sp  — Entra ID service principal (set AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET)
#   entra-wi  — Workload Identity Federation (set AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_FEDERATED_TOKEN_FILE)
ADO_AUTH_METHOD="pat"

# ── Target repository ──
# Absolute path to a local clone of the repo the bot operates ON (creates worktrees
# in, fetches, pushes). This is decoupled from where the harness scripts live, so the
# harness can run from its own checkout (e.g. this repo) while servicing a different
# target repo. If empty, falls back to the git toplevel of the harness scripts.
TARGET_REPO_DIR=""


# ── ntfy ──
# Push-notification relay the bot subscribes to for PR events.
NTFY_URL="https://ntfy.example.com/ntfy"
NTFY_TOPIC="pr-bot"

# ── Claude Code CLI ──
# Set these in .secrets.env:
#   ANTHROPIC_BASE_URL=          # LLM API endpoint
#   ANTHROPIC_AUTH_TOKEN=         # Authentication token
#   ANTHROPIC_MODEL=              # Primary model
#   ANTHROPIC_SMALL_FAST_MODEL=   # Fast model for lighter tasks
CLAUDE_CODE_MAX_OUTPUT_TOKENS="65536"
DISABLE_TELEMETRY="1"
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
DISABLE_ERROR_REPORTING="1"
DISABLE_BUG_COMMAND="1"
DISABLE_NON_ESSENTIAL_MODEL_CALLS="1"

# ── Resource Limits ──
# Tuned from live RSS measurement (2026-06). systemd cap is MemoryMax=3G with
# KillMode=control-group (one Claude breaching it OOM-kills the whole bot), so
# the admission budget sits ~370MB under 3G and concurrency is capped at 2
# (2×MEDIUM≈2200MB + overhead fits; a 3rd breaches). See weight_to_mb in start.sh.
MEMORY_BUDGET_MB="2700"
MAX_CONCURRENT="2"
RESERVED_OVERHEAD_MB="300"
CLAUDE_TIMEOUT="1800"
CLAUDE_MAX_TURNS="50"
CLAUDE_MAX_RETRIES="2"

# ── Orphan reaper (4th OOM-defense layer) ──
# Claude workers shell out to az/azure.cli (python). When a router's session ends
# abnormally, some grandchildren reparent to the systemd --user manager but STAY
# in the pr-bot cgroup, counting against memory.current while being descendants of
# no tracked router — invisible to both watchdog passes. Over days this leaks ~1GB+
# and wedges the bot (budget defers all dispatch; nothing reclaims the leak). The
# reaper diffs the cgroup's process list against the daemon's own subtree and
# terminates the leaked off-tree procs each maintenance tick (and immediately when
# the bot would otherwise deadlock with zero active handlers).
#   ORPHAN_REAP_AGE_SECS   — only reap procs older than this (spares fresh forks).
#   ORPHAN_REAP_GRACE_SECS — TERM→KILL grace per reaped subtree.
#   ORPHAN_REAP_COMM_DENYLIST — comm prefixes spared (detached git/credential
#     housekeeping that legitimately, briefly, leaves the daemon's subtree).
# Inspect (no kills) on the live bot:  ./start.sh --reap-orphans-dryrun
ORPHAN_REAP_ENABLED="true"
ORPHAN_REAP_AGE_SECS="180"
ORPHAN_REAP_GRACE_SECS="5"
ORPHAN_REAP_COMM_DENYLIST="git git-gc git-maintenance git-repack git-pack-objects fsmonitor--daemon git-credential gpg gpg-agent ssh ssh-agent"

# ── macOS jetsam pressure gate (Darwin only; no-op on Linux/systemd) ──
# The cgroup OOM machinery above is Linux-only. On a Mac the bot shares a desktop
# with the user's apps and the real killer is the kernel's jetsam. This gate defers
# a NEW dispatch when the system is genuinely about to kill processes — NOT on the
# routine "warn" the kernel raises constantly on a busy desktop.
#   SYSTEM_PRESSURE_LEVEL_THRESHOLD — kern.memorystatus_vm_pressure_level at/above
#     which to defer. macOS levels: 1=normal, 2=warn, 4=critical. Default 4: the
#     kernel does NOT jetsam-kill at 2 (it just asks apps to drop caches), so 4 is
#     the real signal. Lower to 2 only on a constrained box. (Was effectively 2.)
#   MIN_FREE_SWAP_MB — defer when free swap falls below this. Default 512 (near
#     exhaustion). macOS grows swap dynamically, so ~1.5GB free is normal; the old
#     2048 floor false-fired ~80x/hour, throttling the bot to 1-at-a-time.
#   SYSTEM_PRESSURE_GATE_ENABLED — master switch (true/false).
SYSTEM_PRESSURE_GATE_ENABLED="true"
SYSTEM_PRESSURE_LEVEL_THRESHOLD="4"
MIN_FREE_SWAP_MB="512"

# ── MCP ──
# NOTE: systemd EnvironmentFile does not expand $HOME — use an absolute path here.
TOKEN_SAVIOR_VENV="/home/youruser/.local/share/token-savior-venv"
ENABLE_TOKEN_SAVIOR="true"

# ── Heartbeat ──
HEARTBEAT_INTERVAL_SECS="300"

# ── Work items ──
# When a PR was opened by a service identity (build account), work items can't be
# assigned to it. Set a fallback assignee (e.g. an email/UPN); empty leaves unassigned.
WORKITEM_FALLBACK_OWNER=""
