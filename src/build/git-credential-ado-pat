#!/usr/bin/env bash
# git-credential-ado-pat — Git credential helper that returns ADO_PAT from environment.
#
# Used by the harness so git push/fetch work under systemd/launchd where
# SSH agents aren't available. The PAT comes from config.env → EnvironmentFile.
#
# Install:  git config credential.helper "/path/to/git-credential-ado-pat"
# Requires: ADO_PAT environment variable set
#
# This implements the git credential helper protocol:
#   https://git-scm.com/docs/gitcredentials#_custom_helpers

# Only respond to "get" requests
case "${1:-}" in
  get) ;;
  *)   exit 0 ;;
esac

if [ -z "${ADO_PAT:-}" ]; then
  # Fallback: read ADO_PAT from config.env (for interactive sessions like Claude Code
  # where ADO_PAT isn't in the environment). Checks multiple locations to handle
  # worktrees, the main repo, and relative paths from the script location.
  _cred_script_dir="$(cd "$(dirname "$0")" && pwd)"
  # git rev-parse --git-common-dir resolves to the real .git dir even from worktrees
  _cred_repo_root="$(git rev-parse --git-common-dir 2>/dev/null | sed 's|/\.git$||')"
  for _cred_config in \
    "${_cred_script_dir}/pr-bot/config.env" \
    "${_cred_repo_root}/src/build/pr-bot/config.env"; do
    if [ -f "$_cred_config" ]; then
      ADO_PAT=$(grep '^ADO_PAT=' "$_cred_config" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'"'"' ')
      [ -n "$ADO_PAT" ] && break
    fi
  done
  unset _cred_script_dir _cred_repo_root _cred_config
fi

if [ -z "${ADO_PAT:-}" ]; then
  echo "git-credential-ado-pat: ADO_PAT not set" >&2
  exit 1
fi

# Read the input to find the host being requested
HOST=""
PROTOCOL=""
while IFS='=' read -r key value; do
  [ -z "$key" ] && break
  case "$key" in
    host)     HOST="$value" ;;
    protocol) PROTOCOL="$value" ;;
  esac
done

# Only provide credentials for Azure DevOps hosts
case "$HOST" in
  dev.azure.com|*.visualstudio.com|ssh.dev.azure.com)
    echo "protocol=${PROTOCOL:-https}"
    echo "host=${HOST}"
    echo "username=pat"
    echo "password=${ADO_PAT}"
    echo ""
    ;;
  *)
    # Not an ADO host — don't provide credentials
    exit 0
    ;;
esac
